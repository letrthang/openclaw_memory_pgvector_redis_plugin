# ============================================================
# OpenClaw Memory Plugin — PostgreSQL (pgvector) + Redis
# Environment Configuration
# ============================================================

# ------------------------------------------------------------
# REQUIRED — Must be set before starting the plugin
# ------------------------------------------------------------

# PostgreSQL connection string (with pgvector extension enabled)
DATABASE_URL=postgresql://user:pass@host:25061/db?sslmode=require

# Redis connection string (SSL recommended)
REDIS_URL=rediss://user:pass@host:25061

# OpenAI API key for embedding generation (text-embedding-3-small, 1536 dimensions)
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# OPTIONAL — Defaults shown. Uncomment to override.
# ------------------------------------------------------------

# Human-readable label for what tenant_id represents in this instance.
# Used in logs, error messages, health checks, and startup banner.
# Examples: COMPANY, CUSTOMER, USER, ORG, ADMIN_USER
#TENANCY_NAME=COMPANY

# Fully-qualified PostgreSQL table name (schema.table).
# Allows multiple plugin instances to use separate tables on the same database.
#DB_TABLE_NAME=v1.openclaw_agent_memory

# Redis key namespace prefix.
# Prevents key collisions when multiple plugin instances share the same Redis database.
# Examples: thannong:company, portal:customer, admin:user
#REDIS_KEY_PREFIX=openclaw:memory

